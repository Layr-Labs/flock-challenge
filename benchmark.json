{
  "schemaVersion": 1,
  "name": "flock-blake3-mac",
  "description": "Optimize Flock's Rust prover sources for maximum BLAKE3 compression-proof throughput.",
  "category": "rust",
  "direction": "+",
  "editablePaths": [
    "crates/flock-core/src",
    "crates/flock-prover/src"
  ],
  "setupCommand": ["bash", "-lc", "./setup.sh"],
  "benchmarkCommand": ["bash", "-lc", "./benchmark.sh"],
  "scorePath": "score.json",
  "maxSubmissionBytes": 8388608,
  "runner": {
    "provider": "github-actions",
    "workflow": "benchmark-blake3-mac.yml"
  }
}
